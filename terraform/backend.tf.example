terraform {
  backend "s3" {
    bucket         = "pawfiler-terraform-state"
    key            = "prod/terraform.tfstate"
    region         = "ap-northeast-2"
    dynamodb_table = "pawfiler-terraform-locks"
    encrypt        = true
  }
}

# 사용 방법:
# 1. 이 파일의 주석을 해제하기 전에 S3 버킷과 DynamoDB 테이블을 먼저 생성하세요
# 2. README.md의 "팀 협업 가이드" 섹션 참고
# 3. 주석 해제 후 terraform init -migrate-state 실행
