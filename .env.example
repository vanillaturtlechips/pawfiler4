# PawFiler Environment Configuration

# API Endpoints
VITE_API_BASE_URL=http://localhost:8080
VITE_QUIZ_API_URL=http://localhost:3001/api/quiz
VITE_COMMUNITY_API_URL=http://localhost:50053
VITE_VIDEO_ANALYSIS_API_URL=http://localhost:50054
VITE_PAYMENT_API_URL=http://localhost:50055

# API Mode
# true: Mock API (백엔드 불필요, 메모리 저장)
# false: Real API (PostgreSQL + 백엔드 서비스 필요)
VITE_USE_MOCK_API=true
VITE_USE_MOCK_AUTH=true

# App Config
VITE_APP_NAME=PawFiler
VITE_TUTORIAL_STORAGE_KEY=pawfiler_tutorial_seen

# Backend Setup
# Real API 모드 사용 시:
# 1. cd backend
# 2. ./start-backend.sh
# 3. VITE_USE_MOCK_API=false 설정
# 4. npm run dev 재시작

