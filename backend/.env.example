# CloudFront Domain for Quiz Media
# Get this from: terraform output quiz_media_cloudfront_domain
# Or from AWS Console: CloudFront > Distributions
CLOUDFRONT_DOMAIN=your-cloudfront-domain.cloudfront.net

# CloudFront Domain for Community Media
# terraform output: community_media_cloudfront_url = "https://diqtpoikktqu2.cloudfront.net"
CLOUDFRONT_COMMUNITY_DOMAIN=https://diqtpoikktqu2.cloudfront.net
